FROM golang:1.25.7-alpine AS build

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY cmd ./cmd
COPY internal ./internal

RUN CGO_ENABLED=0 go build -o /out/controller ./cmd/controller
RUN mkdir -p /out/var/lib/neon/controller /out/var/lib/neon/compute
RUN chown -R 65532:65532 /out/var/lib/neon

FROM gcr.io/distroless/static-debian12:nonroot

WORKDIR /app

COPY --from=build /out/controller /app/controller
COPY --from=build --chown=65532:65532 /out/var/lib/neon /var/lib/neon

EXPOSE 8080

ENTRYPOINT ["/app/controller"]
